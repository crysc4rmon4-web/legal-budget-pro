// -----------------------------------------------------------------------------
// MOTOR DE BASE DE DATOS - CARMONA STUDIO
// Arquitectura optimizada para cumplimiento normativo (Ley Antifraude España)
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Desarrollo local con SQLite
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 1. SISTEMA DE IDENTIDAD (Auth.js Models)
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Relación: Un usuario es dueño de una configuración de empresa
  company       Company?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// 2. CONFIGURACIÓN FISCAL (El emisor del presupuesto)
// -----------------------------------------------------------------------------
model Company {
  id            String   @id @default(cuid())
  name          String   // Razón Social
  nif           String   @unique // CIF/NIF validado
  address       String   // Domicilio Fiscal
  email         String
  phone         String?
  
  // Relación con Identidad: Cada empresa pertenece a un Usuario
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relación: Una empresa emite muchos presupuestos
  budgets       Budget[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 3. MINI-CRM (Los clientes)
// -----------------------------------------------------------------------------
model Client {
  id            String   @id @default(cuid())
  name          String   
  nif           String   @unique 
  email         String
  address       String   
  phone         String?
  
  budgets       Budget[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// 4. DOCUMENTACIÓN LEGAL (Presupuestos y Trazabilidad)
// -----------------------------------------------------------------------------
model Budget {
  id              String   @id @default(cuid())
  series          String   @default("PRE") 
  budgetNumber    Int      
  
  companyId       String
  clientId        String
  company         Company  @relation(fields: [companyId], references: [id])
  client          Client   @relation(fields: [clientId], references: [id])

  subtotal        Float    
  taxAmount       Float    
  total           Float    
  
  status          String   @default("DRAFT") 

  // CORE LEGAL ESPAÑA (Trazabilidad Verifactu)
  issueDate       DateTime @default(now()) 
  hash            String?  @unique 
  previousHash    String?  
  isVerifactuSync Boolean  @default(false) 

  lines           BudgetLine[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([series, budgetNumber])
}

model BudgetLine {
  id              String   @id @default(cuid())
  budgetId        String
  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  concept         String   
  quantity        Float    @default(1)
  unitPrice       Float    
  taxRate         Float    
  lineTotal       Float    
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}